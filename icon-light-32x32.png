  {
    label: "Malo",
    description: "Pantalla rota, fallos funcionales, o danos significativos",
    multiplier: 0.4,
  },
]

export function calculatePrice(
  category: Category,
  modelName: string,
  storage: string | null,
  condition: string,
  marginPercent: number
): { clientPrice: number; salePrice: number; profit: number } {
  const model = productModels[category]?.find((m) => m.name === modelName)
  if (!model) return { clientPrice: 0, salePrice: 0, profit: 0 }

  const storageOpt = storageOptions[category]?.find((s) => s.label === storage)
  const conditionOpt = conditionOptions.find((c) => c.label === condition)

  const storageMultiplier = storageOpt?.multiplier ?? 1
  const conditionMultiplier = conditionOpt?.multiplier ?? 1

  const salePrice = Math.round(model.basePrice * storageMultiplier * conditionMultiplier)
  const clientPrice = Math.round(salePrice * (1 - marginPercent / 100))
  const profit = salePrice - clientPrice

  return { clientPrice, salePrice, profit }
}
